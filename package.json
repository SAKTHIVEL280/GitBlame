{
  "name": "gitblame-ai",
  "version": "1.0.1",
  "description": "Explain why any line of code exists using git history and AI",
  "keywords": [
    "git",
    "blame",
    "cli",
    "developer-tools",
    "llm",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SAKTHIVEL280/GitBlame.git"
  },
  "homepage": "https://github.com/SAKTHIVEL280/GitBlame#readme",
  "bugs": {
    "url": "https://github.com/SAKTHIVEL280/GitBlame/issues"
  },
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "gitblame.ai": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist coverage",
    "dev": "tsx src/index.ts",
    "release:check": "npm run typecheck && npm run test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run clean && npm run test && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "chalk": "^5.5.0",
    "commander": "^14.0.1",
    "execa": "^9.6.0",
    "openai": "^5.23.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
